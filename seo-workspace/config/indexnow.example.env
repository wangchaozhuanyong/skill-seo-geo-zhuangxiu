# IndexNow configuration example.
# Do not commit real keys if the key is meant to remain private.

INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
INDEXNOW_HOST=flashcast.com.my
INDEXNOW_KEY=NEEDS_OWNER_INPUT_GENERATE_8_TO_128_CHARS
INDEXNOW_KEY_LOCATION=https://flashcast.com.my/NEEDS_OWNER_INPUT_GENERATE_8_TO_128_CHARS.txt
INDEXNOW_BATCH_SIZE=10000
