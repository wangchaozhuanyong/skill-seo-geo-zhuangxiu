# Google Search Console configuration example.
# Do not commit real credentials or token files.

# Search Console property URL. Must match the verified property exactly.
GSC_SITE_URL=https://flashcast.com.my/

# Option A: service-account JSON file outside this repository.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/outside/repo/google-service-account.json

# Option B: OAuth files outside this repository.
GSC_OAUTH_CLIENT_CONFIG=/absolute/path/outside/repo/oauth-client.json
GSC_OAUTH_TOKEN_JSON=/absolute/path/outside/repo/oauth-token.json
