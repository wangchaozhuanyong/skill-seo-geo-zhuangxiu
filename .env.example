# SEO/GEO environment example.
# Copy values into a private .env file outside commits. Do not commit real secrets.

SEO_GEO_ALLOW_LIVE=0

GSC_SITE_URL=https://flashcast.com.my/
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/outside/repo/google-service-account.json
GSC_OAUTH_CLIENT_CONFIG=/absolute/path/outside/repo/oauth-client.json
GSC_OAUTH_TOKEN_JSON=/absolute/path/outside/repo/oauth-token.json

BAIDU_SITE=https://flashcast.com.my
BAIDU_PUSH_TOKEN=NEEDS_OWNER_INPUT_DO_NOT_COMMIT_REAL_TOKEN
BAIDU_SUBMIT_ENDPOINT=

INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
INDEXNOW_HOST=flashcast.com.my
INDEXNOW_KEY=NEEDS_OWNER_INPUT_DO_NOT_COMMIT_REAL_KEY
INDEXNOW_KEY_LOCATION=https://flashcast.com.my/NEEDS_OWNER_INPUT.txt
INDEXNOW_BATCH_SIZE=10000
